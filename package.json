{
  "name": "nexus-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute nexus-db --remote --file=schema.sql",
    "db:init:local": "wrangler d1 execute nexus-db --local --file=schema.sql",
    "db:seed": "wrangler d1 execute nexus-db --remote --file=seed.sql",
    "db:seed:local": "wrangler d1 execute nexus-db --local --file=seed.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240512.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "hono": "^4.4.0"
  }
}
